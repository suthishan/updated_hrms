# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=your_jwt_secret_here_change_in_production
JWT_EXPIRES_IN=8h

# Email (SMTP)
SMTP_HOST=smtp.company.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=audit-car@company.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=Audit CAR Portal <audit-car@company.com>

# Portal URL (used in email links)
PORTAL_URL=http://intranet.company.com/audit-car

# CORS
CORS_ORIGIN=http://localhost:4200
